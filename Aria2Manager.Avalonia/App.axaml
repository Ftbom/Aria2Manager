<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vms="using:Aria2Manager.Core.ViewModels"
             xmlns:views="using:Aria2Manager.Avalonia.Views"
             xmlns:loc="using:Aria2Manager.Avalonia.Localization"
             x:Class="Aria2Manager.Avalonia.App"
             RequestedThemeVariant="Default">
    
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/app.ico" ToolTipText="Aria2Manager" Clicked="Show_Click">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="{Binding [Show], Source={x:Static loc:AvaloniaLocalizer.Instance}}" Click="Show_Click"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="{Binding [New_Download], Source={x:Static loc:AvaloniaLocalizer.Instance}}" Click="NewDownload_Click"/>
                        <NativeMenuItem Header="{Binding [Settings], Source={x:Static loc:AvaloniaLocalizer.Instance}}" Click="Settings_Click"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="{Binding [Exit], Source={x:Static loc:AvaloniaLocalizer.Instance}}" Click="Exit_Click"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>

    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type vms:MainViewModel}">
            <views:MainWindow />
        </DataTemplate>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Assets/Icons.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>