<mah:MetroWindow x:Class="Aria2Manager.WPF.Views.Aria2TaskInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:Aria2Manager.Core.Localization;assembly=Aria2Manager.Core"
        mc:Ignorable="d"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        TitleBarHeight="25"
        TitleForeground="{DynamicResource MahApps.Brushes.ThemeForeground}"
        WindowTitleBrush="{DynamicResource MahApps.Brushes.Accent3}"
        Title="{x:Static loc:Strings.Properties}" Height="350" Width="600" WindowStartupLocation="CenterOwner">
    <TabControl>
        <TabItem Header="{x:Static loc:Strings.OverView}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="72*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{x:Static loc:Strings.Name}" VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{x:Static loc:Strings.Size}" VerticalAlignment="Center" Grid.Row="1"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{x:Static loc:Strings.Status}" VerticalAlignment="Center" Grid.Row="2"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{x:Static loc:Strings.Progress}" VerticalAlignment="Center" Grid.Row="3"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{x:Static loc:Strings.Download_Path}" VerticalAlignment="Center" Grid.Row="4"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{x:Static loc:Strings.Speed}" VerticalAlignment="Center" Grid.Row="5"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{x:Static loc:Strings.Info_Hash}" VerticalAlignment="Center" Grid.Row="6"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{x:Static loc:Strings.Ratio}" VerticalAlignment="Center" Grid.Row="7"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{x:Static loc:Strings.Seeds_And_Connections}" VerticalAlignment="Center" Grid.Row="8"/>
                <GridSplitter Grid.Column="1" Grid.Row="0" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="1" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="2" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="3" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="4" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="5" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="6" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="7" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="8" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Grid.Row="0" Text="{Binding TaskInfo.Name, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Grid.Row="1" Text="{Binding TaskInfo.Size, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Grid.Row="2" Text="{Binding TaskInfo.Status, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Grid.Row="3" Text="{Binding TaskInfo.Progress, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Grid.Row="4" Text="{Binding TaskInfo.DownloadPath, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Grid.Row="5" Text="{Binding TaskInfo.Speed, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Grid.Row="6" Text="{Binding TaskInfo.Hash, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Grid.Row="7" Text="{Binding TaskInfo.Ratio, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Grid.Row="8" Text="{Binding TaskInfo.Connections, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
            </Grid>
        </TabItem>
        <TabItem Header="{x:Static loc:Strings.Files_List}">
            <ListBox ItemsSource="{Binding TaskInfo.Files}" IsEnabled="{Binding TaskInfo.FileListCheckable, Mode=OneWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name, Mode=OneWay}" IsChecked="{Binding Selected, UpdateSourceTrigger=PropertyChanged}">
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </TabItem>
    </TabControl>
</mah:MetroWindow>
