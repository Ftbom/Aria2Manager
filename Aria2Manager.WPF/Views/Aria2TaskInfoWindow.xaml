<mah:MetroWindow x:Class="Aria2Manager.WPF.Views.Aria2TaskInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:Aria2Manager.WPF.Localization"
        mc:Ignorable="d"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        TitleBarHeight="25"
        TitleForeground="{DynamicResource MahApps.Brushes.ThemeForeground}"
        WindowTitleBrush="{DynamicResource MahApps.Brushes.Accent3}"
        Title="{Binding [Properties], Source={x:Static loc:WpfLocalizer.Instance}}" Height="350" Width="600" WindowStartupLocation="CenterOwner">
    <TabControl>
        <TabItem Header="{Binding [OverView], Source={x:Static loc:WpfLocalizer.Instance}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="72*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Name], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Size], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Row="1"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Status], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Row="2"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Progress], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Row="3"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Download_Path], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Row="4"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Speed], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Row="5"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Info_Hash], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Row="6"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Ratio], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Row="7"/>
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Seeds_And_Connections], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Row="8"/>
                <GridSplitter Grid.Column="1" Grid.Row="0" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="1" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="2" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="3" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="4" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="5" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="6" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="7" HorizontalAlignment="Stretch"/>
                <GridSplitter Grid.Column="1" Grid.Row="8" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Grid.Row="0" Text="{Binding TaskInfo.Name, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="350"
                           TextTrimming="CharacterEllipsis" ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                <TextBlock Grid.Column="2" Grid.Row="1" Text="{Binding TaskInfo.Size, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Grid.Row="2" Text="{Binding TaskInfo.Status, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="3" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding [Downloaded], Source={x:Static loc:WpfLocalizer.Instance}}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TaskInfo.Downloaded, Mode=OneWay}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" Text="," Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding [Uploaded], Source={x:Static loc:WpfLocalizer.Instance}}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TaskInfo.Uploaded, Mode=OneWay}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Grid.Row="4" Text="{Binding TaskInfo.DownloadPath, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="5" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding [Download_Speed], Source={x:Static loc:WpfLocalizer.Instance}}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TaskInfo.DownloadSpeed, Mode=OneWay}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" Text="," Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding [Upload_Speed], Source={x:Static loc:WpfLocalizer.Instance}}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TaskInfo.UploadSpeed, Mode=OneWay}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Grid.Row="6" Text="{Binding TaskInfo.Hash, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Grid.Row="7" Text="{Binding TaskInfo.Ratio, Mode=OneWay}" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="8" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding [Connections], Source={x:Static loc:WpfLocalizer.Instance}}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TaskInfo.Connections, Mode=OneWay}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" Text="," Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding [Seeds], Source={x:Static loc:WpfLocalizer.Instance}}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TaskInfo.Seeders, Mode=OneWay}" Margin="0,0,2,0" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </TabItem>
        <TabItem Header="{Binding [Files_List], Source={x:Static loc:WpfLocalizer.Instance}}">
            <ListBox ItemsSource="{Binding TaskInfo.Files}" IsEnabled="{Binding TaskInfo.FileListCheckable, Mode=OneWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name, Mode=OneWay}" IsChecked="{Binding Selected, UpdateSourceTrigger=PropertyChanged}">
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </TabItem>
        <TabItem Header="{Binding [Settings], Source={x:Static loc:WpfLocalizer.Instance}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="10*"/>
                </Grid.RowDefinitions>
                <Button Content="{Binding [Save], Source={x:Static loc:WpfLocalizer.Instance}}" IsEnabled="{Binding TaskInfo.CanChangeOptions}"
                        HorizontalAlignment="Center" Grid.Row="8" VerticalAlignment="Center" MinWidth="75" Command="{Binding ChangeOptionsCommand}"/>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [HTTP_User], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [HTTP_Passwd], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Column="2"/>
                    <TextBox Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding TaskInfo.HttpUser}" VerticalAlignment="Center" MinWidth="166" IsEnabled="{Binding TaskInfo.IsHttp}"/>
                    <TextBox Grid.Column="3" HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding TaskInfo.HttpPasswd}" VerticalAlignment="Center" MinWidth="166" IsEnabled="{Binding TaskInfo.IsHttp}"/>
                </Grid>
                <Separator Grid.Row="1"/>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Seed_Ratio], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Seed_Time], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Column="2"/>
                    <TextBox Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding TaskInfo.SeedRatio}" VerticalAlignment="Center" Width="166" IsEnabled="{Binding TaskInfo.IsBittorrent}"/>
                    <TextBox Grid.Column="3" HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding TaskInfo.SeedTime}" VerticalAlignment="Center" Width="166" IsEnabled="{Binding TaskInfo.IsBittorrent}"/>
                </Grid>
                <Separator Grid.Row="3"/>
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Proxy_Address], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Proxy_Port], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Column="2"/>
                    <TextBox Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding TaskInfo.ProxyAddress}" VerticalAlignment="Center" MinWidth="166" IsEnabled="{Binding TaskInfo.IsHttp}"/>
                    <TextBox Grid.Column="3" HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding TaskInfo.ProxyPort}" VerticalAlignment="Center" MinWidth="166" IsEnabled="{Binding TaskInfo.IsHttp}"/>
                </Grid>
                <Separator Grid.Row="5"/>
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Proxy_User], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding [Proxy_Passwd], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center" Grid.Column="2"/>
                    <TextBox Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding TaskInfo.ProxyUser}" VerticalAlignment="Center" MinWidth="166" IsEnabled="{Binding TaskInfo.IsHttp}"/>
                    <TextBox Grid.Column="3" HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding TaskInfo.ProxyPasswd}" VerticalAlignment="Center" MinWidth="166" IsEnabled="{Binding TaskInfo.IsHttp}"/>
                </Grid>
                <Separator Grid.Row="7"/>
            </Grid>
        </TabItem>
    </TabControl>
</mah:MetroWindow>
