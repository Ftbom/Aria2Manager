<mah:MetroWindow x:Class="Aria2Manager.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:Aria2Manager.WPF.Localization"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        TitleBarHeight="25"
        TitleForeground="{DynamicResource MahApps.Brushes.ThemeForeground}"
        WindowTitleBrush="{DynamicResource MahApps.Brushes.Accent3}"
        ShowIconOnTitleBar="False"
        Closing="MainWindow_Closing"
        Title="Aria2Manager" Height="480" Width="900" Icon="/Resources/app.ico" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <DockPanel>
        <Menu DockPanel.Dock="Top" MinHeight="30">
            <MenuItem Header="{Binding [Edit], Source={x:Static loc:WpfLocalizer.Instance}}">
                <MenuItem Header="{Binding [Add], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding OpenAria2NewTaskCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="+" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding [Pause], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding PauseTaskCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF04C;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding [Resume], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding UnpauseTaskCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF04B;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding [Remove], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding RemoveTaskCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF1F8;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding [Properties], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding OpenAria2TaskInfoCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xf15c;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{Binding [Resume_All], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding UnpauseAllTaskCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF144;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding [Pause_All], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding PauseAllTaskCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF28B;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding [Purge_All], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding PurgeAllTaskCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xf12d;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{Binding [Tools], Source={x:Static loc:WpfLocalizer.Instance}}">
                <MenuItem Header="{Binding [Aria2_Servers], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding OpenAria2ServersCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF828;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding [Aria2_Options], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding OpenAria2OptionsCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF1DE;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding [Program_Settings], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding OpenSettingsCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF013;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{Binding [Exit], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding ExitCommand}" >
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF00D;" FontFamily="{StaticResource FontAwesome}" FontSize="20" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{Binding [Help], Source={x:Static loc:WpfLocalizer.Instance}}" InputGestureText="">
                <MenuItem Header="{Binding [Aria2_Website], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding OpenAria2WebsiteCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF0AC;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding [Aria2_Status], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding OpenAria2StatusCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF059;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{Binding [About], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding OpenAboutCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xF05A;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>
        <ToolBarTray DockPanel.Dock="Top" MinHeight="37">
            <ToolBar>
                <Button HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,5,0" Command="{Binding OpenAria2NewTaskCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent}" FontSize="24" Margin="0,0,2,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [Add], Source={x:Static loc:WpfLocalizer.Instance}}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,5,0" Command="{Binding RemoveTaskCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xF1F8;" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent}" FontSize="24" Margin="0,0,2,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [Remove], Source={x:Static loc:WpfLocalizer.Instance}}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,5,0" Command="{Binding UnpauseTaskCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xF04B;" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent}" FontSize="24" Margin="0,0,2,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [Resume], Source={x:Static loc:WpfLocalizer.Instance}}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,5,0" Command="{Binding PauseTaskCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xF04C;" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent}" FontSize="24" Margin="0,0,2,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [Pause], Source={x:Static loc:WpfLocalizer.Instance}}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,5,0"  Command="{Binding OpenAria2TaskInfoCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xf15c;" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent}" FontSize="24" Margin="0,0,2,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [Properties], Source={x:Static loc:WpfLocalizer.Instance}}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,5,0" Command="{Binding UnpauseAllTaskCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xF144;" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent}" FontSize="24" Margin="0,0,2,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [Resume_All], Source={x:Static loc:WpfLocalizer.Instance}}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,5,0" Command="{Binding PauseAllTaskCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xF28B;" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent}" FontSize="24" Margin="0,0,2,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [Pause_All], Source={x:Static loc:WpfLocalizer.Instance}}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,5,0" Command="{Binding PurgeAllTaskCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xf12d;" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent}" FontSize="24" Margin="0,0,2,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [Purge_All], Source={x:Static loc:WpfLocalizer.Instance}}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </ToolBar>
        </ToolBarTray>
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource MahApps.Brushes.Gray10}">
            <StatusBarItem Height="37" VerticalAlignment="Center" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding ServerNames, Mode=OneWay}" IsEnabled="{Binding CanSwitchServer}" SelectedItem="{Binding CurrentServerName}" Margin="2,0,2,0"/>
                    <Ellipse Width="16" Height="16">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource MahApps.Brushes.Border.NonActive}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ServerStatus.IsConnected, Mode=OneWay}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem Height="37" VerticalAlignment="Center" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" Text="{Binding [Upload_Speed], Source={x:Static loc:WpfLocalizer.Instance}}" Margin="0,0,2,0"/>
                    <TextBlock Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" TextWrapping="Wrap" Text="{Binding ServerUploadSpeed, Mode=OneWay}" Margin="0,0,2,0"/>
                    <TextBlock Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" TextWrapping="Wrap" Text="," Margin="0,0,2,0"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" Text="{Binding [Download_Speed], Source={x:Static loc:WpfLocalizer.Instance}}" Margin="0,0,2,0"/>
                    <TextBlock Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" TextWrapping="Wrap" Text="{Binding ServerDownloadSpeed, Mode=OneWay}" Margin="0,0,2,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="100*"/>
            </Grid.ColumnDefinitions>
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"/>
            <ListView Grid.Column="2" ItemsSource="{Binding Aria2TaskCollection}" SelectedValue="{Binding SelectedTaskGid}" SelectedValuePath="Gid">
                <ListView.ContextMenu >
                    <ContextMenu>
                        <MenuItem Header="{Binding [Pause], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding PauseTaskCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xF04C;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding [Resume], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding UnpauseTaskCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xF04B;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding [Remove], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding RemoveTaskCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xF1F8;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding [Properties], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding OpenAria2TaskInfoCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xf15c;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding [Open_File_Location], Source={x:Static loc:WpfLocalizer.Instance}}" Command="{Binding OpenFileLocationCommand}" Visibility="{Binding ServerStatus.IsLocal, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xf07c;" FontFamily="{StaticResource FontAwesome}" FontSize="15" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{Binding [Name], Source={x:Static loc:WpfLocalizer.Instance}}" Width="200" DisplayMemberBinding="{Binding Name, Mode=OneWay}"/>
                        <GridViewColumn Header="{Binding [Progress], Source={x:Static loc:WpfLocalizer.Instance}}" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <ProgressBar Maximum="100" Value="{Binding Progress, Mode=OneWay}" Width="110" Height="15"/>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Progress, Mode=OneWay}"/>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{Binding [Size], Source={x:Static loc:WpfLocalizer.Instance}}" Width="120" DisplayMemberBinding="{Binding Size, Mode=OneWay}"/>
                        <GridViewColumn Header="{Binding [Downloaded], Source={x:Static loc:WpfLocalizer.Instance}}" Width="120" DisplayMemberBinding="{Binding Downloaded, Mode=OneWay}"/>
                        <GridViewColumn Header="{Binding [ETA], Source={x:Static loc:WpfLocalizer.Instance}}" Width="120" DisplayMemberBinding="{Binding ETA, Mode=OneWay}"/>
                        <GridViewColumn Header="{Binding [Status], Source={x:Static loc:WpfLocalizer.Instance}}" Width="120" DisplayMemberBinding="{Binding Status, Mode=OneWay}"/>
                        <GridViewColumn Header="{Binding [Download_Speed], Source={x:Static loc:WpfLocalizer.Instance}}" Width="120" DisplayMemberBinding="{Binding DownloadSpeed, Mode=OneWay}"/>
                        <GridViewColumn Header="{Binding [Uploaded], Source={x:Static loc:WpfLocalizer.Instance}}" Width="120" DisplayMemberBinding="{Binding Uploaded, Mode=OneWay}"/>
                        <GridViewColumn Header="{Binding [Upload_Speed], Source={x:Static loc:WpfLocalizer.Instance}}" Width="120" DisplayMemberBinding="{Binding UploadSpeed, Mode=OneWay}"/>
                        <GridViewColumn Header="{Binding [Ratio], Source={x:Static loc:WpfLocalizer.Instance}}" Width="120" DisplayMemberBinding="{Binding Ratio, Mode=OneWay}"/>
                        <GridViewColumn Header="{Binding [Connections], Source={x:Static loc:WpfLocalizer.Instance}}" Width="120" DisplayMemberBinding="{Binding Connections, Mode=OneWay}"/>
                        <GridViewColumn Header="{Binding [Seeds], Source={x:Static loc:WpfLocalizer.Instance}}" Width="120" DisplayMemberBinding="{Binding NumSeeders, Mode=OneWay}"/>
                    </GridView>
                </ListView.View>
            </ListView>
            <ListBox SelectedValuePath="Tag" SelectedValue="{Binding SelectedStatus}">
                <ListBoxItem Tag="all" Margin="5,5,0,5" IsSelected="True">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xF111;" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent3}" FontSize="20" Margin="0,0,5,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [TaskStatus_All], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="active" Margin="5,0,0,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xF358;" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent3}" FontSize="20" Margin="0,0,5,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [TaskStatus_Active], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="waiting" Margin="5,0,0,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xF017;" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent3}" FontSize="20" Margin="0,0,5,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [TaskStatus_Waiting], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="stopped" Margin="5,0,0,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xF28D;" FontFamily="{StaticResource FontAwesome}" Foreground="{DynamicResource MahApps.Brushes.Accent3}" FontSize="20" Margin="0,0,5,0" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding [TaskStatus_Stopped], Source={x:Static loc:WpfLocalizer.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
